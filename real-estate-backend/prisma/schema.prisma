
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  AGENT
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}

enum PlotStatus {
  AVAILABLE
  BOOKED
  SOLD
}

enum BookingStatus {
  ACTIVE
  CANCELLED
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model Company {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users         User[]
  projects      Project[]
  sales         Sale[]
  refreshTokens RefreshToken[]

  // NOTE: Company has no FK fields to index — it's the root tenant model
}

//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  bookings      Booking[]
  sales         Sale[]
  refreshTokens RefreshToken[]

  // companyId FK is already indexed by MySQL automatically
  // Adding explicit indexes only for non-FK query patterns
  @@index([role])
  @@index([isActive])
  @@index([role, isActive]) // composite: filter by role AND active
}

//////////////////////////////////////////////////////

model Project {
  id        String        @id @default(uuid())
  name      String
  location  String
  status    ProjectStatus @default(ACTIVE)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  plots Plot[]

  // companyId FK is already indexed by MySQL automatically
  @@index([status])
  @@index([isActive])
  @@index([status, isActive]) // composite: list active projects by status
}

//////////////////////////////////////////////////////

model Plot {
  id         String     @id @default(uuid())
  plotNumber String
  area       Float
  price      Float
  status     PlotStatus @default(AVAILABLE)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  bookings Booking[]
  sale     Sale?

  @@unique([plotNumber, projectId])

  // projectId FK is already indexed by MySQL automatically
  @@index([status])
  @@index([isActive])
  @@index([status, isActive]) // composite: find available/booked/sold plots
}

//////////////////////////////////////////////////////

model Booking {
  id            String        @id @default(uuid())
  clientName    String
  bookingAmount Float
  bookingDate   DateTime      @default(now())
  status        BookingStatus @default(ACTIVE)

  plotId String
  plot   Plot   @relation(fields: [plotId], references: [id])

  agentId String
  agent   User   @relation(fields: [agentId], references: [id])

  // plotId and agentId FK indexes created automatically by MySQL
  @@index([status])
  @@index([bookingDate]) // sort/filter by date
  @@index([agentId, status]) // composite: agent's active bookings
}

//////////////////////////////////////////////////////

model Sale {
  id         String   @id @default(uuid())
  plotId     String   @unique
  agentId    String
  companyId  String
  saleAmount Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  isActive   Boolean  @default(true)

  plot    Plot    @relation(fields: [plotId], references: [id])
  agent   User    @relation(fields: [agentId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  // plotId, agentId, companyId FK indexes created automatically by MySQL
  @@index([createdAt]) // sort by date
  @@index([companyId, createdAt]) // tenant revenue queries (dashboard trends)
  @@index([agentId, createdAt])   // agent performance queries
}

//////////////////////////////////////////////////////

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  companyId String?
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  // userId and companyId FK indexes created automatically by MySQL
  @@index([isActive])
  @@index([expiresAt]) // cleanup job: find expired tokens
}
